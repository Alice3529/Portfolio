using Cysharp.Threading.Tasks;

namespace CorgiPlay.PuzzleGame.Hints
{
    /// <summary>
    /// Defines a handler that can plan and execute a hint within the chain.
    /// </summary>
    public interface IHintHandler
    {
        UniTask<bool> Execute(HintHandlerChain chain);
        bool TryGetPlan(HintHandlerChain chain, out IHintPlan plan);
    }
}
